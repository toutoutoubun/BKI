{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BKI",
  "version": "0.1.0",
  "identifier": "app.bki.local",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BKI",
        "width": 1280,
        "height": 840,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["../python"]
  }
}

