{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BKI",
  "version": "0.1.0",
  "identifier": "com.toutoutoubun.bki",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BKI",
        "width": 1280,
        "height": 840,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "BKI Contributors",
    "copyright": "Copyright © 2026 BKI Contributors",
    "category": "Education",
    "shortDescription": "Bibliometric and keyword intelligence desktop app",
    "longDescription": "BKI is a local-first desktop application for corpus management, keyword intelligence, qualitative coding, R-style statistics, and research export workflows.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["../python"]
  }
}
